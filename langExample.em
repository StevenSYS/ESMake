> "exampleLang.h"
%mode "lang"
%preLang "LANG_ERROR_"
! | Legend | Meaning                     |
! | ------ | --------------------------- |
! | >      | Output(s) - First line only |
! | %      | Setting                     |
! | +      | Item                        |
! | -      | Item (Switch Default)       |
! | !      | Comment                     |
! | \      | Escape                      |

+EXAMPLE "Example Error"